extends layout

block content
  h1=title

  if(toShow == null)
    h2 No instance to delete 
  else 
    - let technologyid = toShow._id
    - let technology_brand = toShow.brand 
    - let technology_price = toShow.price
    - let technology_category = toShow.category
    script let actionid = "#{actionid}"
    div 
      div.row
        div(class='technologyAttr mr-3') Technology ID is:
        div #{technologyid}
      div.row
        div(class='technologyAttr mr-3') Technology Brand is:
        div #{technology_brand}
      div.row 
        div(class='technologyAttr mr-3') Technology price  is:
        div #{technology_price}
      div.row 
        div(class='technologyAttr mr-3') Technology Category is:
        div #{technology_category}
      
    button(class="btn btn-danger m-2" onclick="deleteOnid()") Delete
    button(class="btn btn-secondary m-2" onclick="cancel()") Cancel

  script. 
   function cancel() {
    window.location.href = '/technology'
   }
  script. 
   function deleteOnid() {
    console.log("starting delete")
    fetch(actionid, {
     method: 'DELETE',
    }).then((resp) => {
     return resp.text(); // or resp.text() or whatever the server sends
    }).then((body) => {
     alert("Delete succeded")
     window.location.href = '/technology'
    }).catch((error) => {
     alert("Delete failed " + error)
    });
   }